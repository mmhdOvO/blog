# =============================================================================
# 项目环境变量配置文件
# 使用说明：复制此文件为 .env，然后修改相应配置
# =============================================================================

# -----------------------------------------------------------------------------
# 服务器配置
# -----------------------------------------------------------------------------
# 服务端口
SERVER_PORT=8082

# Spring 配置文件激活
SPRING_PROFILES_ACTIVE=prod

# -----------------------------------------------------------------------------
# MySQL 数据库配置
# -----------------------------------------------------------------------------
# 数据库名称
DB_NAME=blog_db

# 数据库端口（宿主机映射端口）
DB_PORT=3306

# 数据库 root 密码（仅用于 MySQL 容器初始化）
DB_ROOT_PASSWORD=123456

# 数据库用户名
DB_USERNAME=root

# 数据库密码
DB_PASSWORD=123456

# -----------------------------------------------------------------------------
# Redis 配置（可选）
# -----------------------------------------------------------------------------
# Redis 端口
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# JWT 配置
# -----------------------------------------------------------------------------
# JWT 密钥（生产环境务必修改为复杂随机字符串）
# 可以使用在线工具生成：https://www.allkeysgenerator.com/Random/Security-Encryption-Key-Generator.aspx
JWT_SECRET=your-secret-key-please-change-in-production-keep-it-safe

# JWT 过期时间（毫秒，默认 24 小时）
JWT_EXPIRATION=86400000

# -----------------------------------------------------------------------------
# DeepSeek AI 内容审核配置（可选）
# -----------------------------------------------------------------------------
# DeepSeek API Key（申请地址：https://platform.deepseek.com/）
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# DeepSeek 模型名称
DEEPSEEK_MODEL=deepseek-chat

# -----------------------------------------------------------------------------
# 其他配置
# -----------------------------------------------------------------------------
# 时区设置
TZ=Asia/Shanghai
